<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Status Page" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app %>
  </head>

  <body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; max-width: 800px; margin: 0 auto; padding: 20px; background: #f8f9fa;">
    <header style="margin-bottom: 30px;">
      <h1 style="margin: 0;"><a href="/" style="text-decoration: none; color: #333;">Status Page</a></h1>
    </header>

    <% if notice.present? %>
      <div style="background: #d4edda; color: #155724; padding: 12px 16px; border-radius: 4px; margin-bottom: 20px;">
        <%= notice %>
      </div>
    <% end %>

    <% if alert.present? %>
      <div style="background: #f8d7da; color: #721c24; padding: 12px 16px; border-radius: 4px; margin-bottom: 20px;">
        <%= alert %>
      </div>
    <% end %>

    <main>
      <%= yield %>
    </main>

    <footer style="margin-top: 40px; padding-top: 20px; border-top: 1px solid #dee2e6; color: #6c757d; font-size: 14px;">
      <p>Amenitiz Status Page &mdash; <%= Time.current.strftime("%Y") %></p>
    </footer>
  </body>
</html>
